# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=ucos_db

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=ucos_super_secret_jwt_key_change_in_production_2026
JWT_EXPIRES_IN=24h

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Email (SMTP) ──────────────────────────────────────────────
# For Gmail: enable "App Password" in Google Account > Security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=UCOS System <your@gmail.com>

# ── Frontend URL (for CORS) ───────────────────────────────────
FRONTEND_URL=http://localhost:3000
